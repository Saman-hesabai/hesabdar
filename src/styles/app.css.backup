:root{--blue:#2563eb;--blue2:#1d4ed8;--green:#10b981;--dark:#0f172a;--muted:#64748b;--glass:rgba(255,255,255,.68);--line:rgba(226,232,240,.8);--shadow:0 22px 70px rgba(37,99,235,.14)}*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;font-family:Tahoma,Arial,sans-serif;background:radial-gradient(circle at top right,#dbeafe 0,#f8fafc 34%,#eef5ff 100%);color:var(--dark)}button,input,select{font:inherit}button{cursor:pointer}.auth{min-height:100vh;display:grid;place-items:center;padding:24px;background:linear-gradient(135deg,#eff6ff,#ecfeff)}.auth-card{width:min(430px,100%);background:var(--glass);backdrop-filter:blur(24px);border:1px solid rgba(255,255,255,.9);border-radius:34px;padding:30px;box-shadow:var(--shadow)}.auth h1{font-size:44px;margin:0}.auth p{color:var(--muted)}.auth input,.grid input,.grid select,.assistant input,.search input{width:100%;border:1px solid #dbe3ef;border-radius:20px;background:rgba(255,255,255,.88);padding:16px 18px;margin:8px 0;outline:0}.auth input:focus,.grid input:focus,.assistant input:focus,.search input:focus{border-color:#93c5fd;box-shadow:0 0 0 4px #bfdbfe66}.auth button,.grid button,.hero button,.assistant-row button,.exit,.mini-action,.fab{border:0;border-radius:22px;background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff;padding:15px 22px;font-weight:800;display:inline-flex;gap:8px;align-items:center;justify-content:center;box-shadow:0 14px 35px rgba(37,99,235,.25)}.link{background:transparent!important;color:var(--blue)!important;box-shadow:none!important}.app{max-width:760px;margin:auto;padding:16px 16px 96px}.top{position:sticky;top:0;z-index:10;display:flex;align-items:center;justify-content:space-between;gap:10px;padding:10px 0 12px;background:linear-gradient(180deg,rgba(248,250,252,.95),rgba(248,250,252,.65));backdrop-filter:blur(18px)}.top h1{margin:0;font-size:32px}.top p{margin:5px 0;color:var(--muted)}.exit{background:#eef5ff;color:var(--blue);box-shadow:none}.hero{margin:10px 0 14px;padding:22px;border-radius:34px;background:linear-gradient(135deg,rgba(255,255,255,.75),rgba(255,255,255,.45));border:1px solid rgba(255,255,255,.95);box-shadow:var(--shadow);backdrop-filter:blur(24px);position:relative;overflow:hidden}.hero:before{content:'';position:absolute;inset:auto -60px -90px auto;width:190px;height:190px;background:radial-gradient(circle,#60a5fa66,transparent 65%)}.hero h2{margin:0 0 8px;font-size:30px}.hero p{color:var(--muted);line-height:1.8;margin:0 0 14px}.hero-actions{display:flex;gap:8px;flex-wrap:wrap}.hero button.dark{background:linear-gradient(135deg,#0f172a,#1e293b)}.mini-action{padding:13px 15px;border-radius:18px;background:rgba(255,255,255,.78);color:#0f172a;box-shadow:none;border:1px solid #e2e8f0}.stats{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin:14px 0}.stat{position:relative;overflow:hidden;background:linear-gradient(135deg,#2563eb,#1d4ed8);color:#fff;border-radius:26px;padding:16px;min-height:96px;display:flex;flex-direction:column;gap:7px;box-shadow:0 20px 50px #2563eb35}.stat:nth-child(2){background:linear-gradient(135deg,#0891b2,#10b981)}.stat:nth-child(3){background:linear-gradient(135deg,#7c3aed,#2563eb)}.stat:nth-child(4){background:linear-gradient(135deg,#f59e0b,#ef4444)}.stat svg{opacity:.9}.stat span{opacity:.9;font-size:13px}.stat b{font-size:19px}.glass{background:rgba(255,255,255,.72);border:1px solid rgba(255,255,255,.92);border-radius:32px;margin:12px 0;overflow:hidden;box-shadow:0 16px 50px rgba(100,116,139,.14);backdrop-filter:blur(24px)}.glass-head{width:100%;border:0;background:transparent;padding:18px;display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:14px;text-align:right;color:#0f172a}.glass-head .icon{width:58px;height:58px;border-radius:22px;display:grid;place-items:center;background:linear-gradient(135deg,#2563eb,#10b981);color:#fff;box-shadow:0 14px 30px #2563eb35}.glass-head b{display:block;font-size:21px}.glass-head small{display:block;margin-top:6px;color:var(--muted);line-height:1.6}.rot{transform:rotate(180deg)}.glass-body{padding:0 18px 20px;animation:fade .22s ease}.grid{display:grid;gap:8px;background:rgba(248,250,252,.72);padding:15px;border-radius:26px;margin:12px 0;border:1px solid rgba(226,232,240,.7)}.grid h3{margin:0 0 4px}.toggle{display:grid;grid-template-columns:1fr 1fr;background:#eaf2ff;padding:6px;border-radius:22px}.toggle button{background:transparent;color:#2563eb;box-shadow:none}.toggle .on{background:#2563eb;color:#fff;box-shadow:0 10px 25px #2563eb30}.calc{padding:14px;border-radius:18px;border:1px dashed #cbd5e1;color:#475569;background:white}.search{display:flex;align-items:center;gap:8px}.search svg{color:#64748b}.list,.trash{display:grid;gap:10px;margin-top:12px}.row{display:flex;align-items:center;justify-content:space-between;gap:10px;background:rgba(255,255,255,.9);border:1px solid #e2e8f0;border-radius:22px;padding:13px}.row small{display:block;color:#64748b;margin-top:4px;line-height:1.7}.row button{border:0;border-radius:16px;padding:10px 12px;background:#eef5ff;color:#2563eb;display:inline-flex;align-items:center;gap:5px}.row .danger,.danger{background:#fee2e2!important;color:#dc2626!important}.trash{background:#fff7ed;border:1px solid #fed7aa;border-radius:24px;padding:12px}.assistant-panel{position:fixed;inset:auto 12px 84px 12px;max-width:740px;margin:auto;z-index:20;background:rgba(255,255,255,.88);border:1px solid #fff;border-radius:32px;box-shadow:0 30px 90px rgba(15,23,42,.24);backdrop-filter:blur(24px);padding:16px;animation:pop .2s ease}.assistant{display:grid;gap:12px}.assistant-title{display:flex;align-items:center;justify-content:space-between}.assistant-title h3{margin:0}.bubble{border-radius:24px;padding:16px;background:#eff6ff;color:#1e3a8a;line-height:1.9}.bubble.user{background:#f1f5f9;color:#0f172a}.assistant-row{display:grid;grid-template-columns:1fr auto auto;gap:8px}.assistant-row button{padding:0;width:54px;height:54px}.assistant-row .mic{background:linear-gradient(135deg,#16a34a,#0d9488)}.fab{position:fixed;left:18px;bottom:18px;z-index:25;width:70px;height:70px;border-radius:26px;background:linear-gradient(135deg,#2563eb,#10b981);padding:0}.fab.pulse:after{content:'';position:absolute;inset:-8px;border-radius:32px;border:2px solid #22c55e55;animation:pulse 1.6s infinite}.report,.about{background:white;border-radius:24px;padding:18px;line-height:2}.snack{position:sticky;top:76px;z-index:15;background:#0f172a;color:#fff;padding:12px 14px;border-radius:20px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 15px 35px #0f172a33}.snack button{background:transparent;border:0;color:#fff}.bottom-nav{position:fixed;right:12px;left:12px;bottom:12px;margin:auto;max-width:760px;z-index:14;display:grid;grid-template-columns:repeat(4,1fr);gap:6px;background:rgba(255,255,255,.8);border:1px solid #fff;border-radius:26px;padding:8px;backdrop-filter:blur(18px);box-shadow:0 20px 50px #0f172a20}.bottom-nav button{border:0;background:transparent;border-radius:20px;padding:9px 4px;color:#64748b;font-size:12px;display:grid;place-items:center;gap:4px}.bottom-nav .active{background:#eff6ff;color:#2563eb}.quick-chips{display:flex;gap:8px;overflow:auto;padding-bottom:4px}.chip{white-space:nowrap;border:1px solid #dbeafe!important;background:#eff6ff!important;color:#2563eb!important;box-shadow:none!important;padding:11px 13px!important;border-radius:18px!important}.toast-msg{margin-top:12px;color:#ef4444;line-height:1.8}@keyframes fade{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}@keyframes pop{from{opacity:0;transform:translateY(20px) scale(.98)}to{opacity:1;transform:none}}@keyframes pulse{0%{transform:scale(.9);opacity:1}100%{transform:scale(1.18);opacity:0}}@media(max-width:560px){.app{padding:14px 14px 96px}.top h1{font-size:28px}.hero h2{font-size:26px}.glass-head b{font-size:20px}.stat{min-height:90px;padding:14px}.stat b{font-size:17px}.assistant-panel{bottom:88px}.hero-actions .mini-action{flex:1}.stats{grid-template-columns:repeat(2,1fr)}}
.clickable{cursor:pointer}.clickable:hover{transform:translateY(-1px);border-color:#93c5fd}.modal-backdrop{position:fixed;inset:0;z-index:40;background:rgba(15,23,42,.45);display:grid;place-items:center;padding:14px;backdrop-filter:blur(8px)}.modal-card{width:min(720px,100%);max-height:92vh;overflow:auto;background:#f8fafc;border-radius:30px;padding:18px;box-shadow:0 30px 100px rgba(15,23,42,.35)}.modal-head{display:flex;justify-content:space-between;align-items:center;gap:12px}.modal-head h2{margin:0}.modal-head small{color:#64748b}.room-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:14px 0}.room-stats div{background:white;border-radius:20px;padding:13px;border:1px solid #e2e8f0}.room-stats span{display:block;color:#64748b;font-size:12px}.room-stats b{display:block;margin-top:7px}.edit-box{display:grid;gap:8px;background:white;border:1px solid #e2e8f0;border-radius:24px;padding:14px;margin:12px 0}.edit-box h3{display:flex;gap:7px;align-items:center;margin:0}.edit-box input,.edit-box textarea,.edit-box select,.staff input{width:100%;border:1px solid #dbe3ef;border-radius:16px;padding:13px;background:#fff}.edit-box textarea{min-height:80px;resize:vertical}.edit-box button,.staff>button{border:0;border-radius:17px;background:#2563eb;color:#fff;padding:12px;font-weight:700;display:flex;gap:7px;justify-content:center}.tx-list{display:grid;gap:9px}.tx-card{display:flex;justify-content:space-between;gap:10px;background:white;border:1px solid #e2e8f0;border-radius:20px;padding:13px}.tx-card small{display:block;color:#64748b;margin-top:5px}.tx-card p{margin:8px 0 0}.tx-actions{display:flex;gap:5px}.tx-actions button{border:0;border-radius:12px;padding:9px;color:#2563eb;background:#eff6ff}.staff{display:grid;gap:10px}.hint{background:#eff6ff;border-radius:16px;padding:12px;color:#1e40af}.permissions{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;background:#fff;border-radius:20px;padding:12px}.permissions label{display:flex;align-items:center;gap:7px;font-size:13px}.permissions input{width:auto}.bottom-nav svg{width:18px;height:18px}@media(max-width:560px){.room-stats{grid-template-columns:1fr}.permissions{grid-template-columns:1fr}.modal-card{padding:14px;border-radius:24px}}

.room-snack{position:relative;top:auto;margin:12px 0}.transaction-editor{border:2px solid #93c5fd;box-shadow:0 12px 35px #2563eb22}.editor-actions{display:grid;grid-template-columns:1fr auto;gap:8px}.cancel-btn{background:#e2e8f0!important;color:#334155!important}.manager-shortcut{background:#eefbf5!important;color:#047857!important;border-color:#a7f3d0!important}.staff-manager-card{display:grid;gap:14px}.manager-intro{display:flex;gap:12px;align-items:center;background:linear-gradient(135deg,#eff6ff,#ecfdf5);padding:16px;border-radius:22px;border:1px solid #bfdbfe}.manager-intro h3,.manager-intro p{margin:0}.manager-intro p{color:#64748b;margin-top:5px;line-height:1.7}.staff-form{display:grid;gap:10px;background:#fff;padding:14px;border-radius:22px;border:1px solid #e2e8f0}.staff-form>button,.staff-permission-editor>button{border:0;border-radius:17px;background:#2563eb;color:#fff;padding:12px;font-weight:700;display:flex;gap:7px;justify-content:center;align-items:center}.manager-message{padding:12px 14px;border-radius:16px;background:#eff6ff;color:#1e40af}.empty-state{color:#64748b;text-align:center}.staff-item{background:#fff;border:1px solid #e2e8f0;border-radius:22px;padding:12px}.staff-summary{display:flex;justify-content:space-between;gap:10px;align-items:center}.staff-summary small{display:block;color:#64748b;margin-top:5px}.staff-actions{display:flex;gap:6px;flex-wrap:wrap}.staff-actions button{border:0;border-radius:13px;padding:9px;background:#eff6ff;color:#2563eb;display:flex;align-items:center;gap:5px}.staff-permission-editor{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-top:12px;padding-top:12px;border-top:1px solid #e2e8f0}.staff-permission-editor label{display:flex;align-items:center;gap:6px;font-size:13px}.staff-permission-editor>button{grid-column:1/-1}.assistant-row button:disabled,.staff-form button:disabled{opacity:.55;cursor:not-allowed}@media(max-width:560px){.staff-summary{align-items:flex-start;flex-direction:column}.staff-permission-editor{grid-template-columns:1fr}.editor-actions{grid-template-columns:1fr}}

/* ===== Backup & Restore v0.9 ===== */

.backup-manager {
  display: grid;
  gap: 14px;
}

.backup-warning {
  padding: 16px;
  border: 1px solid rgba(37, 99, 235, 0.18);
  border-radius: 22px;
  background: rgba(239, 246, 255, 0.75);
  line-height: 1.9;
}

.backup-warning b {
  display: block;
  margin-bottom: 6px;
  font-size: 1.05rem;
}

.backup-warning p {
  margin: 3px 0;
  color: #64748b;
  font-size: 0.9rem;
}

.backup-primary,
.backup-secondary,
.backup-restore,
.backup-cancel {
  width: 100%;
  min-height: 58px;
  border: 0;
  border-radius: 20px;
  font-family: inherit;
  font-size: 1rem;
  font-weight: 800;
  cursor: pointer;
}

.backup-primary {
  color: white;
  background: linear-gradient(135deg, #2563eb, #14b8a6);
  box-shadow: 0 14px 30px rgba(37, 99, 235, 0.2);
}

.backup-secondary {
  color: #1e3a8a;
  background: rgba(219, 234, 254, 0.85);
  border: 1px solid rgba(37, 99, 235, 0.18);
}

.backup-primary:disabled,
.backup-secondary:disabled,
.backup-restore:disabled,
.backup-cancel:disabled {
  opacity: 0.55;
  cursor: not-allowed;
}

.backup-file-input {
  display: none;
}

.backup-preview {
  display: grid;
  gap: 10px;
  padding: 16px;
  border-radius: 22px;
  border: 1px solid rgba(20, 184, 166, 0.2);
  background: rgba(240, 253, 250, 0.8);
}

.backup-preview h3 {
  margin: 0 0 5px;
}

.backup-preview > div {
  display: flex;
  justify-content: space-between;
  gap: 15px;
  padding: 10px 0;
  border-bottom: 1px dashed rgba(100, 116, 139, 0.2);
}

.backup-preview > div span {
  color: #64748b;
}

.backup-preview > div b {
  text-align: left;
  overflow-wrap: anywhere;
}

.backup-restore {
  margin-top: 8px;
  color: white;
  background: linear-gradient(135deg, #059669, #14b8a6);
}

.backup-cancel {
  min-height: 46px;
  color: #b91c1c;
  background: rgba(254, 226, 226, 0.85);
}

.backup-message {
  white-space: pre-line;
  padding: 14px;
  border-radius: 18px;
  background: rgba(224, 231, 255, 0.8);
  color: #1e3a8a;
  line-height: 1.9;
}

.auto-backup-box{
  display:grid;
  gap:12px;
  padding:16px;
  border-radius:20px;
  background:rgba(241,245,249,.85);
  border:1px solid rgba(100,116,139,.15);
}

.auto-backup-box label{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
}

.auto-backup-box select{
  min-height:44px;
  padding:6px 12px;
  border-radius:14px;
  border:1px solid rgba(100,116,139,.25);
  font-family:inherit;
}

.auto-backup-box small{
  color:#64748b;
  line-height:1.8;
}

.auto-backup-toggle{
  font-weight:800;
}

.auto-backup-toggle input{
  width:22px;
  height:22px;
}

.amount-words{
  display:block;
  margin-top:7px;
  color:#64748b;
  font-size:.82rem;
  line-height:1.7;
}

/* ===== Real tabs, trash and transaction editor ===== */

.app.tab-customers .page-operations,
.app.tab-customers .glass:not([data-section="customers"]){
  display:none;
}

.app.tab-reports .page-operations,
.app.tab-reports .glass:not([data-section="reports"]){
  display:none;
}

.app.tab-assistant .page-operations,
.app.tab-assistant .glass:not([data-section="assistant"]){
  display:none;
}

.app.tab-operations .glass[data-section="customers"],
.app.tab-operations .glass[data-section="reports"],
.app.tab-operations .glass[data-section="assistant"]{
  display:none;
}

.bottom-nav button{
  position:relative;
  transition:.2s ease;
}

.bottom-nav button.active{
  color:#2563eb;
  transform:translateY(-2px);
}

.bottom-nav button.active::before{
  content:"";
  position:absolute;
  top:-7px;
  left:25%;
  right:25%;
  height:4px;
  border-radius:999px;
  background:#2563eb;
}

.customer-tab-add{
  margin-bottom:15px;
  padding:15px;
  border-radius:20px;
  background:rgba(239,246,255,.8);
  border:1px solid rgba(37,99,235,.15);
}

.customer-tab-add h3{
  display:flex;
  align-items:center;
  gap:8px;
}

.trash-open-button{
  width:100%;
  min-height:54px;
  margin-bottom:14px;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:9px;
  border:0;
  border-radius:18px;
  background:rgba(254,226,226,.9);
  color:#b91c1c;
  font-family:inherit;
  font-weight:800;
}

.trash-open-button span{
  min-width:26px;
  height:26px;
  display:grid;
  place-items:center;
  border-radius:50%;
  background:#b91c1c;
  color:#fff;
}

.trash-room{
  max-height:88vh;
  overflow:auto;
}

.trash-tabs{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:8px;
  margin:12px 0;
  padding:6px;
  border-radius:18px;
  background:#eef2ff;
}

.trash-tabs button{
  min-height:46px;
  border:0;
  border-radius:14px;
  background:transparent;
  font-family:inherit;
  font-weight:800;
}

.trash-tabs button.active{
  color:white;
  background:#2563eb;
}

.trash-items{
  display:grid;
  gap:9px;
  max-height:48vh;
  overflow:auto;
  padding:4px;
}

.trash-select-row{
  display:flex;
  align-items:flex-start;
  gap:12px;
  padding:13px;
  border:1px solid rgba(100,116,139,.15);
  border-radius:17px;
  background:rgba(248,250,252,.95);
}

.trash-select-row input{
  width:22px;
  height:22px;
  flex:0 0 auto;
}

.trash-select-row span{
  display:grid;
  gap:4px;
}

.trash-select-row small{
  color:#64748b;
  line-height:1.7;
}

.trash-actions{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:9px;
  margin-top:15px;
}

.trash-actions button{
  min-height:53px;
  border:0;
  border-radius:17px;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:7px;
  font-family:inherit;
  font-weight:800;
  color:white;
  background:#059669;
}

.trash-actions button.danger{
  background:#dc2626;
}

.trash-actions button:disabled{
  opacity:.45;
}

/* Existing transaction editor becomes a real popup */
.transaction-editor{
  position:fixed !important;
  z-index:10050;
  top:50%;
  left:50%;
  width:min(90vw,520px);
  max-height:86vh;
  overflow:auto;
  transform:translate(-50%,-50%);
  padding:20px !important;
  border-radius:24px !important;
  background:white !important;
  box-shadow:0 30px 90px rgba(15,23,42,.35) !important;
}

.transaction-editor::before{
  content:"";
  position:fixed;
  z-index:-1;
  inset:-100vh -100vw;
  background:rgba(15,23,42,.55);
  backdrop-filter:blur(4px);
}

@media(max-width:560px){
  .trash-actions{
    grid-template-columns:1fr;
  }
}


/* ===== v0.9 hamburger menu, compact home and theme ===== */

:root[data-theme="dark"]{
  color-scheme:dark;
}

html[data-theme="dark"] body{
  background:#08111f;
  color:#e5eefc;
}

html[data-theme="dark"] .app{
  background:linear-gradient(180deg,#091321,#111d31);
  color:#e5eefc;
}

html[data-theme="dark"] .top,
html[data-theme="dark"] .hero,
html[data-theme="dark"] .glass,
html[data-theme="dark"] .bottom-nav,
html[data-theme="dark"] .modal-card,
html[data-theme="dark"] .menu-modal-card,
html[data-theme="dark"] .side-drawer{
  background:rgba(15,27,46,.96)!important;
  color:#eef5ff!important;
  border-color:rgba(148,163,184,.16)!important;
}

html[data-theme="dark"] .glass-head,
html[data-theme="dark"] .bottom-nav button,
html[data-theme="dark"] .toolbar-icon,
html[data-theme="dark"] .drawer-head button{
  color:#e5eefc;
}

html[data-theme="dark"] input,
html[data-theme="dark"] select,
html[data-theme="dark"] textarea{
  background:#0c1728!important;
  color:#f8fafc!important;
  border-color:#334155!important;
}

html[data-theme="dark"] .row,
html[data-theme="dark"] .tx-card,
html[data-theme="dark"] .edit-box,
html[data-theme="dark"] .settings-panel,
html[data-theme="dark"] .setting-row,
html[data-theme="dark"] .setting-toggle,
html[data-theme="dark"] .trash-select-row{
  background:#111f34!important;
  color:#eef5ff!important;
  border-color:#334155!important;
}

html[data-theme="dark"] small,
html[data-theme="dark"] p{
  color:#aebbd0;
}

html[data-theme="dark"] .transaction-editor{
  background:#111f34!important;
  color:#eef5ff!important;
}

.app-toolbar{
  display:grid;
  grid-template-columns:48px 1fr 52px;
  align-items:center;
  gap:10px;
  position:sticky;
  top:0;
  z-index:1000;
  padding:14px 18px!important;
}

.toolbar-title{
  text-align:right;
  min-width:0;
}

.toolbar-title h1{
  margin:0;
}

.toolbar-title p{
  margin:4px 0 0;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}

.toolbar-icon{
  width:46px;
  height:46px;
  border:0;
  border-radius:16px;
  display:grid;
  place-items:center;
  background:rgba(37,99,235,.08);
}

.power-switch{
  border:0;
  background:transparent;
  padding:0;
  width:50px;
  height:62px;
  display:grid;
  place-items:center;
}

.power-track{
  width:34px;
  height:58px;
  border-radius:20px;
  background:#dbe7f7;
  padding:4px;
  display:flex;
  align-items:flex-end;
  transition:.25s;
}

.power-switch.is-dark .power-track{
  align-items:flex-start;
  background:#20314b;
}

.power-knob{
  width:26px;
  height:26px;
  border-radius:50%;
  display:grid;
  place-items:center;
  background:white;
  color:#f59e0b;
  box-shadow:0 4px 10px rgba(15,23,42,.2);
  transition:.25s;
}

.power-switch.is-dark .power-knob{
  background:#17243a;
  color:#93c5fd;
}

.compact-hero{
  padding:18px 22px!important;
}

.compact-hero h2{
  margin:0 0 6px;
}

.compact-hero p{
  margin:0 0 14px;
}

.compact-hero .hero-actions{
  margin-top:0;
}

.drawer-backdrop{
  position:fixed;
  inset:0;
  z-index:12000;
  border:0;
  background:rgba(2,6,23,.52);
  backdrop-filter:blur(3px);
}

.side-drawer{
  position:fixed;
  z-index:12001;
  top:0;
  right:0;
  width:min(86vw,360px);
  height:100dvh;
  padding:18px;
  background:#fff;
  box-shadow:-20px 0 60px rgba(15,23,42,.28);
  animation:drawerIn .22s ease;
}

@keyframes drawerIn{
  from{
    transform:translateX(100%);
  }

  to{
    transform:translateX(0);
  }
}

.drawer-head{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:8px 4px 18px;
  border-bottom:1px solid rgba(100,116,139,.15);
}

.drawer-head>div{
  display:grid;
  gap:3px;
}

.drawer-head b{
  font-size:1.15rem;
}

.drawer-head button{
  border:0;
  background:transparent;
}

.drawer-menu{
  display:grid;
  gap:9px;
  padding-top:16px;
}

.drawer-menu button{
  min-height:58px;
  border:1px solid rgba(100,116,139,.15);
  border-radius:18px;
  background:rgba(248,250,252,.92);
  display:grid;
  grid-template-columns:28px 1fr auto;
  align-items:center;
  gap:10px;
  padding:10px 14px;
  text-align:right;
  font-family:inherit;
  color:#172033;
}

.drawer-menu button span{
  font-weight:800;
}

.drawer-menu button small{
  min-width:25px;
  height:25px;
  border-radius:50%;
  display:grid;
  place-items:center;
  background:#e0e7ff;
  color:#1d4ed8;
}

.drawer-menu .drawer-logout{
  margin-top:10px;
  color:#b91c1c;
  background:#fff1f2;
}

html[data-theme="dark"] .drawer-menu button{
  background:#111f34;
  color:#eef5ff;
  border-color:#334155;
}

.menu-modal-backdrop{
  position:fixed;
  inset:0;
  z-index:12500;
  display:grid;
  place-items:center;
  padding:18px;
  background:rgba(2,6,23,.58);
  backdrop-filter:blur(5px);
}

.menu-modal-card{
  width:min(94vw,700px);
  max-height:90dvh;
  overflow:auto;
  border-radius:28px;
  padding:20px;
  background:#fff;
  box-shadow:0 30px 90px rgba(2,6,23,.35);
}

.settings-panel{
  display:grid;
  gap:12px;
}

.setting-row,
.setting-toggle{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:14px;
  padding:15px;
  border:1px solid rgba(100,116,139,.15);
  border-radius:18px;
  background:#f8fafc;
}

.setting-row>span,
.setting-toggle>span{
  display:grid;
  gap:4px;
}

.setting-row select{
  min-width:130px;
}

.setting-toggle input{
  width:24px;
  height:24px;
}

.menu-about{
  line-height:2;
}

.font-small{
  font-size:.92rem;
}

.font-normal{
  font-size:1rem;
}

.font-large{
  font-size:1.1rem;
}

@media(max-width:560px){
  .app-toolbar{
    grid-template-columns:44px 1fr 46px;
    padding:12px 14px!important;
  }

  .toolbar-title h1{
    font-size:1.55rem;
  }

  .power-switch{
    width:44px;
  }

  .compact-hero{
    padding:15px 18px!important;
  }

  .compact-hero p{
    font-size:.92rem;
  }

  .setting-row,
  .setting-toggle{
    align-items:flex-start;
  }

  .setting-row{
    flex-direction:column;
  }

  .setting-row select{
    width:100%;
  }
}

/* ===== v0.9.1 usability fixes ===== */
.customer-picker{position:relative}
.customer-picker-trigger{width:100%;min-height:52px;border:1px solid rgba(100,116,139,.22);border-radius:16px;background:#fff;display:grid;grid-template-columns:24px 1fr 20px;align-items:center;gap:8px;padding:0 14px;font-family:inherit;text-align:right;color:inherit}
.picker-backdrop{position:fixed;inset:0;z-index:13000;display:grid;place-items:center;padding:18px;background:rgba(2,6,23,.58);backdrop-filter:blur(4px)}
.picker-card{width:min(94vw,560px);max-height:84vh;overflow:auto;border-radius:26px;background:#fff;padding:18px;box-shadow:0 30px 90px rgba(2,6,23,.35)}
.picker-search{margin:12px 0}
.picker-list{display:grid;gap:8px;max-height:56vh;overflow:auto}
.picker-list button{min-height:56px;border:1px solid rgba(100,116,139,.14);border-radius:16px;background:#f8fafc;padding:10px 13px;display:flex;align-items:center;justify-content:space-between;text-align:right;font-family:inherit;color:inherit}
.picker-list button span{display:grid;gap:3px}

.mini-calculator{display:grid;gap:8px}
.calculator-toggle{min-height:46px;border:1px solid rgba(37,99,235,.18);border-radius:15px;background:#eff6ff;color:#1d4ed8;display:flex;align-items:center;justify-content:center;gap:8px;font-family:inherit;font-weight:800}
.calculator-panel{display:grid;gap:10px;padding:13px;border:1px solid rgba(37,99,235,.14);border-radius:18px;background:rgba(239,246,255,.78)}
.calculator-result{padding:10px;border-radius:13px;background:#fff;text-align:center}
.calculator-keys{display:grid;grid-template-columns:repeat(4,1fr);gap:7px}
.calculator-keys button{min-height:42px;border:0;border-radius:12px;background:#fff;font-weight:800}
.calculator-keys .calc-clear{grid-column:span 2;background:#fee2e2;color:#b91c1c}
.calculator-keys .calc-apply{grid-column:span 2;background:#2563eb;color:#fff}

.assistant-confirm{display:grid;gap:10px;padding:14px;border:1px solid rgba(245,158,11,.3);border-radius:18px;background:#fffbeb}
.confirm-title{display:flex;align-items:center;gap:8px;color:#92400e}
.assistant-confirm p{display:flex;justify-content:space-between;gap:12px;margin:0}
.assistant-confirm select,.single-candidate{min-height:48px;border-radius:14px;border:1px solid rgba(100,116,139,.25);padding:10px;background:#fff;font-family:inherit}
.confirm-actions{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.confirm-actions button{min-height:48px;border:0;border-radius:14px;font-family:inherit;font-weight:800;display:flex;align-items:center;justify-content:center;gap:6px;background:#059669;color:#fff}
.confirm-actions .cancel-btn{background:#fee2e2;color:#b91c1c}

.back-button{border:0;border-radius:14px;background:#eef2ff;color:#1d4ed8;min-height:42px;padding:0 12px;display:flex;align-items:center;gap:6px;font-family:inherit;font-weight:800}
.customer-room-card{max-height:92vh;overflow:auto}
.room-quick-actions{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin:14px 0}
.room-quick-actions button{min-height:52px;border:0;border-radius:16px;background:#dc2626;color:#fff;font-family:inherit;font-weight:800;display:flex;align-items:center;justify-content:center;gap:7px}
.room-quick-actions .payment{background:#059669}
.quick-transaction-box{display:grid;gap:10px;padding:15px;border:1px solid rgba(37,99,235,.16);border-radius:20px;background:#f8fbff;margin-bottom:14px}

.global-toast{position:fixed;z-index:15000;top:18px;left:50%;transform:translateX(-50%);width:min(92vw,460px);min-height:54px;border-radius:17px;padding:11px 14px;display:flex;align-items:center;justify-content:space-between;gap:12px;color:#fff;box-shadow:0 18px 50px rgba(15,23,42,.3);animation:toastIn .22s ease}
.global-toast.success{background:#059669}.global-toast.error{background:#dc2626}.global-toast button{border:0;background:transparent;color:#fff}
@keyframes toastIn{from{opacity:0;transform:translate(-50%,-12px)}to{opacity:1;transform:translate(-50%,0)}}

html[data-theme="dark"] .picker-card,
html[data-theme="dark"] .customer-picker-trigger,
html[data-theme="dark"] .picker-list button,
html[data-theme="dark"] .calculator-panel,
html[data-theme="dark"] .calculator-result,
html[data-theme="dark"] .assistant-confirm,
html[data-theme="dark"] .assistant-confirm select,
html[data-theme="dark"] .single-candidate,
html[data-theme="dark"] .quick-transaction-box{background:#111f34!important;color:#eef5ff!important;border-color:#334155!important}

@media(max-width:560px){.confirm-actions,.room-quick-actions{grid-template-columns:1fr}.modal-head{gap:8px}.back-button{padding:0 9px;font-size:.88rem}}

/* v0.9.1 voice, calculator and PDF report fixes */
.calculator-keys button{color:#172033!important;font-size:1.1rem!important;background:#fff!important;border:1px solid rgba(100,116,139,.18)!important}
.calculator-keys button:active{transform:scale(.96);background:#dbeafe!important}
.calculator-keys .calc-clear{color:#b91c1c!important;background:#fee2e2!important}
.calculator-keys .calc-apply{color:#fff!important;background:#2563eb!important}
.calculator-display{direction:ltr!important;text-align:left!important;font-size:1.15rem!important;font-weight:800!important}
html[data-theme="dark"] .calculator-keys button{color:#eef5ff!important;background:#1e293b!important;border-color:#475569!important}
html[data-theme="dark"] .calculator-keys .calc-clear{background:#4c1d1d!important;color:#fecaca!important}
html[data-theme="dark"] .calculator-keys .calc-apply{background:#2563eb!important;color:#fff!important}
.customer-pdf-button{width:100%;min-height:56px;margin:12px 0 16px;border:0;border-radius:18px;background:linear-gradient(135deg,#0f766e,#2563eb);color:#fff;font-family:inherit;font-weight:900;display:flex;align-items:center;justify-content:center;gap:9px}
.customer-pdf-button:disabled{opacity:.55}
.assistant-confirm select{width:100%;min-height:52px}

/* v0.9.3 shop-style calculator */
.shop-calculator{padding:14px!important;background:linear-gradient(180deg,#eef4ff,#dce8ff)!important;border:1px solid rgba(37,99,235,.2)!important}
.shop-calc-screen{display:grid;gap:8px;padding:12px;border-radius:16px;background:#f7f8ef;border:1px solid rgba(100,116,139,.22);box-shadow:inset 0 2px 8px rgba(15,23,42,.08)}
.shop-calc-screen .calculator-display{min-height:48px!important;border:0!important;background:transparent!important;padding:4px 8px!important;font-size:1.18rem!important}
.shop-calc-screen .calculator-result{background:transparent!important;border-top:1px dashed rgba(100,116,139,.28);border-radius:0;padding:9px 4px 2px;font-size:1.05rem}
.shop-calc-keys{display:grid;grid-template-columns:repeat(7,minmax(0,1fr));grid-template-areas:
"gt sqrt n7 n8 n9 mul mu"
"ce percent n4 n5 n6 div back"
"ca ca n1 n2 n3 sub sub"
"n0 n00 n000 dot plus equal equal";gap:8px;direction:ltr}
.shop-calc-keys button{min-width:0;min-height:54px;border:1px solid rgba(71,85,105,.28)!important;border-radius:10px!important;background:linear-gradient(180deg,#fff,#edf1f7)!important;color:#172033!important;font-size:1rem!important;font-weight:900!important;box-shadow:0 3px 0 rgba(71,85,105,.2);font-family:inherit}
.shop-calc-keys button:active{transform:translateY(2px)!important;box-shadow:0 1px 0 rgba(71,85,105,.2)!important}
.shop-calc-keys .op{background:linear-gradient(180deg,#93a8d9,#6179b5)!important;color:#fff!important}
.shop-calc-keys .danger-key,.shop-calc-keys .danger-op{background:linear-gradient(180deg,#ff9b91,#e35b50)!important;color:#fff!important}
.shop-calc-keys .plus-key{background:linear-gradient(180deg,#455d91,#263a68)!important;color:#fff!important;font-size:1.5rem!important}
.shop-calc-keys .equals-key{background:linear-gradient(180deg,#6479aa,#354a7d)!important;color:#fff!important;font-size:1.35rem!important}
.shop-calc-keys .muted-key{background:linear-gradient(180deg,#aab8dc,#7f92c4)!important;color:#fff!important}
.k-gt{grid-area:gt}.k-sqrt{grid-area:sqrt}.k-7{grid-area:n7}.k-8{grid-area:n8}.k-9{grid-area:n9}.k-mul{grid-area:mul}.k-mu{grid-area:mu}
.k-ce{grid-area:ce}.k-percent{grid-area:percent}.k-4{grid-area:n4}.k-5{grid-area:n5}.k-6{grid-area:n6}.k-div{grid-area:div}.k-back{grid-area:back}
.k-ca{grid-area:ca}.k-1{grid-area:n1}.k-2{grid-area:n2}.k-3{grid-area:n3}.k-sub{grid-area:sub}
.k-0{grid-area:n0}.k-00{grid-area:n00}.k-000{grid-area:n000}.k-dot{grid-area:dot}.k-plus{grid-area:plus}.k-equals{grid-area:equal}
.shop-apply{width:100%;min-height:54px;margin-top:2px;border:0;border-radius:15px;background:linear-gradient(135deg,#2563eb,#1d4ed8);color:#fff;font-family:inherit;font-size:1.05rem;font-weight:900}
.shop-apply:disabled{opacity:.5}
html[data-theme="dark"] .shop-calculator{background:linear-gradient(180deg,#17243a,#111c2f)!important}
html[data-theme="dark"] .shop-calc-screen{background:#20291e!important;color:#eef5ff}
html[data-theme="dark"] .shop-calc-keys button{background:linear-gradient(180deg,#334155,#1e293b)!important;color:#eef5ff!important;border-color:#64748b!important}
html[data-theme="dark"] .shop-calc-keys .op{background:linear-gradient(180deg,#5b6f9d,#344a78)!important}
html[data-theme="dark"] .shop-calc-keys .danger-key,html[data-theme="dark"] .shop-calc-keys .danger-op{background:linear-gradient(180deg,#b94e46,#7f1d1d)!important}
@media(max-width:560px){
  .shop-calc-keys{grid-template-columns:repeat(6,minmax(0,1fr));grid-template-areas:
  "gt sqrt n7 n8 n9 mul"
  "ce percent n4 n5 n6 div"
  "ca ca n1 n2 n3 sub"
  "n0 n00 n000 dot plus equal"}
  .k-mu,.k-back{display:none!important}
  .shop-calc-keys button{min-height:56px;font-size:.98rem!important}
}

/* ===== Hesabdar V1 complete visual rewrite ===== */
:root{--v1-green:#13b981;--v1-blue:#3977f6;--v1-ink:#172033;--v1-bg:#f4f7fb}
body{background:var(--v1-bg)!important}
.app{max-width:720px;margin:auto;padding-bottom:110px!important;background:linear-gradient(180deg,#f9fbff 0,#f3f6fb 100%);min-height:100vh}
.app-toolbar{background:#fff!important;border-bottom:1px solid #edf0f5!important;box-shadow:none!important;position:sticky;top:0;z-index:100}
.toolbar-title h1{font-size:1.45rem!important}.toolbar-title p{color:#7b8496!important}
.v1-welcome{padding:18px 18px 4px;display:grid;gap:14px}
.v1-brand-row{display:flex;align-items:center;justify-content:space-between}.v1-brand-row small{color:#8a94a7}.v1-brand-row h2{margin:3px 0 0;color:var(--v1-ink);font-size:1.55rem}
.v1-refresh{width:46px;height:46px;border:0;border-radius:50%;background:#fff;color:var(--v1-blue);box-shadow:0 8px 25px rgba(31,41,55,.08)}
.v1-balance-card{padding:20px;border-radius:26px;background:linear-gradient(135deg,#2769ed,#4b8cff);color:#fff;box-shadow:0 18px 40px rgba(57,119,246,.24);display:grid;gap:8px}
.v1-balance-card>span{opacity:.88}.v1-balance-card>strong{font-size:1.75rem}.v1-balance-card>strong small{font-size:.85rem;font-weight:500}
.v1-balance-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:8px}.v1-balance-grid>div{padding:12px;border-radius:17px;background:rgba(255,255,255,.14);display:grid;gap:5px}.v1-balance-grid small{opacity:.85}.v1-balance-grid b{font-size:1rem}
.v1-quick-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}.v1-quick-row button{min-height:58px;border:0;border-radius:18px;color:#fff;font-family:inherit;font-weight:900;display:flex;align-items:center;justify-content:center;gap:7px}.v1-quick-row .debt{background:#f15f73}.v1-quick-row .payment{background:var(--v1-green)}
.stats{padding:10px 18px!important;grid-template-columns:1fr 1fr!important;gap:10px!important}.stat{background:#fff!important;color:var(--v1-ink)!important;border:1px solid #edf0f5!important;border-radius:20px!important;box-shadow:0 8px 25px rgba(31,41,55,.055)!important}.stat svg{color:var(--v1-blue)}
.glass{margin:12px 18px!important;border:0!important;border-radius:24px!important;background:#fff!important;box-shadow:0 10px 30px rgba(31,41,55,.06)!important}.glass-head{padding:17px!important}.glass-head .icon{background:#eaf2ff!important;color:var(--v1-blue)!important}
.grid input,.search,.customer-picker-trigger{border-radius:16px!important;background:#f7f9fc!important;border:1px solid #e8edf4!important}.grid>button{border-radius:16px!important;background:var(--v1-blue)!important}
.row{border-radius:17px!important;background:#f8fafc!important;border:1px solid #edf1f6!important;margin-bottom:8px!important}
.bottom-nav{left:50%!important;transform:translateX(-50%)!important;width:min(calc(100% - 24px),696px)!important;bottom:12px!important;border-radius:25px!important;background:rgba(255,255,255,.94)!important;border:1px solid #e9edf4!important;box-shadow:0 14px 45px rgba(31,41,55,.16)!important;backdrop-filter:blur(18px)}
.bottom-nav button.active{color:var(--v1-blue)!important;background:#edf4ff!important;border-radius:18px!important}
.fab{background:linear-gradient(135deg,#168ff2,#13b981)!important}
html[data-theme="dark"] body,html[data-theme="dark"] .app{background:#0c1422!important}html[data-theme="dark"] .v1-brand-row h2{color:#eef5ff}html[data-theme="dark"] .app-toolbar,html[data-theme="dark"] .glass,html[data-theme="dark"] .stat{background:#111f34!important;border-color:#24344d!important;color:#eef5ff!important}
@media(max-width:430px){.v1-balance-card>strong{font-size:1.48rem}.v1-welcome{padding-inline:14px}.glass{margin-inline:14px!important}.stats{padding-inline:14px!important}}

.stat-button{font-family:inherit;text-align:right;cursor:pointer;width:100%;}
.stat-button:active{transform:scale(.98);}
.glass{scroll-margin-top:110px;}
